{
  "solution": "11-risk-tiered-rollout",
  "tier": "recommended",
  "controls": [
    "1.9",
    "1.11",
    "1.12",
    "4.12"
  ],
  "waveDefinitions": [
    {
      "waveNumber": 0,
      "name": "Wave 0 - Pilot 50 Users",
      "maxUsers": 50,
      "includedRiskTiers": [
        "Tier1"
      ],
      "approvalMode": "business-owner",
      "gateCriteria": [
        "scannerComplete",
        "minimumReadinessScore",
        "serviceHealthGreen",
        "supportDeskCoverage"
      ]
    },
    {
      "waveNumber": 1,
      "name": "Wave 1 - 500 Users Tier 1 and Tier 2",
      "maxUsers": 500,
      "includedRiskTiers": [
        "Tier1",
        "Tier2"
      ],
      "approvalMode": "control-owner",
      "gateCriteria": [
        "wave0Success",
        "dlpValidatedForTier2",
        "supervisionCoverage",
        "incidentThreshold"
      ]
    },
    {
      "waveNumber": 2,
      "name": "Wave 2 - Full Tier 1 and Tier 2",
      "maxUsers": 2000,
      "includedRiskTiers": [
        "Tier1",
        "Tier2"
      ],
      "approvalMode": "rollout-board",
      "gateCriteria": [
        "trainingCompletion",
        "backlogWithinThreshold",
        "dashboardHealthy"
      ]
    }
  ],
  "notifications": {
    "mode": "standard",
    "summaryRecipients": [
      "copilot-operations@contoso.example",
      "control-owners@contoso.example"
    ],
    "approvalChannel": "RTR-governance-alerts"
  },
  "approvalWorkflow": {
    "enabled": true,
    "cabApprovalRequired": false,
    "requiredApprovers": [
      "BusinessOwner",
      "ControlOwner"
    ]
  },
  "analytics": {
    "vivaInsightsEnabled": true
  },
  "resilience": {
    "doraGateRequired": false
  },
  "gateThresholds": {
    "minimumPilotReadinessPercent": 95,
    "minimumExpansionReadinessPercent": 90,
    "maximumOpenIncidents": 3
  },
  "evidenceRetentionDays": 90,
  "notificationMode": "standard"
}
