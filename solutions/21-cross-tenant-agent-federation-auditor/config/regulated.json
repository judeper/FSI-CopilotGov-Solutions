{
  "solution": "21-cross-tenant-agent-federation-auditor",
  "tier": "regulated",
  "primaryControls": ["2.17", "2.16"],
  "supportingControls": ["1.10", "2.13", "2.14", "4.13"],
  "federationReviewCadenceDays": 7,
  "mcpConnectionReviewRequired": true,
  "mcpConnectionRevalidationRequired": true,
  "agentIdGovernanceReviewRequired": true,
  "agentIdCredentialReviewEnabled": true,
  "crossTenantAuditLogRetentionDays": 1825,
  "evidenceRetentionDays": 1825,
  "notificationMode": "strict",
  "copilotStudioPublishing": {
    "allowMultiTenant": true,
    "requireApprovedAudienceList": true,
    "blockUnreviewedTargetTenants": true,
    "requireSecondPartyApproval": true
  },
  "mcpConnectionReview": {
    "requireAuthenticationReview": true,
    "maxConnectionReviewAgeDays": 14,
    "requireScopeReview": true,
    "requireIndependentReviewer": false,
    "alertOnConnectionReviewStale": true
  },
  "agentIdCredentialReview": {
    "maxCredentialAgeDays": 90,
    "requireConditionalAccessCoverage": true,
    "alertOnCredentialReviewOverdue": true
  },
  "auditAggregation": {
    "exportToImmutableStorage": true,
    "storageAccountEnvVar": "IMMUTABLE_STORAGE_ACCOUNT",
    "containerName": "ctaf-evidence",
    "retentionPolicyDays": 1825
  }
}
