{
  "tier": "regulated",
  "controls": ["1.2", "1.4", "1.6", "2.5"],
  "evidenceOutputs": ["drift-report", "baseline-snapshot", "reversion-log"],
  "evidenceRetentionDays": 2555,
  "maxSitesPerRun": 1000,
  "scanFrequencyHours": 12,
  "enableAlertNotifications": true,
  "enableAutoReversion": true,
