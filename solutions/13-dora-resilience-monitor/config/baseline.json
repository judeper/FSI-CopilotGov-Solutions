{
  "solution": "13-dora-resilience-monitor",
  "tier": "baseline",
  "controls": ["2.7", "4.9", "4.10", "4.11"],
  "evidenceRetentionDays": 90,
  "notificationMode": "summary",
  "serviceHealthPollingIntervalMinutes": 60,
  "incidentClassification": {
    "enabled": true,
    "severityThresholds": {
      "major": { "downtimeMinutes": 60, "affectedUserPct": 50 },
      "significant": { "downtimeMinutes": 15, "affectedUserPct": 20 },
      "minor": { "downtimeMinutes": 1, "affectedUserPct": 5 }
    }
  },
  "resilienceTestTracking": {
    "enabled": false,
    "annualTestRequiredByDORA": true
  },
  "sentinelIntegration": {
    "enabled": false
  },
  "powerAutomateFlow": {
    "description": "Service health alert flow - documentation-first; deploy manually from docs/deployment-guide.md",
    "triggerType": "scheduled",
    "scheduleIntervalHours": 1
  }
}
