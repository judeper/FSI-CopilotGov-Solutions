    "Early Adopters": {
      "targetPercentage": 15,
      "enabled": true,
      "approvalRequired": true
    },
    "General Availability": {
      "targetPercentage": 80,
      "enabled": true,
      "approvalRequired": true
    },
    "Restricted": {
      "targetPercentage": 0,
      "enabled": true,
      "approvalRequired": true
    }
  },
  "features": [
    {
