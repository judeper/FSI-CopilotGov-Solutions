    "graphPermissions": [
      "AuditLog.Read.All",
      "RecordsManagement.Read.All"
    ],
    "notificationChannel": "atm-governance-alerts",
    "evidenceOutputPath": ".\\artifacts\\atm",
    "dataverseTables": {
      "baseline": "fsi_cg_atm_baseline",
      "assessmentHistory": "fsi_cg_atm_assessmenthistory",
