  "defaults": {
    "copilotPolicyLocation": "Microsoft 365 Copilot and Copilot Chat",
    "copilotPolicyLocationScope": {
      "locationExclusivity": "Selecting this policy location disables all other locations for that DLP policy.",
      "adminUnitsSupported": false
    },
    "copilotCapabilities": [
      {
        "id": "sensitiveInformationTypesInPrompts",
        "displayName": "Sensitive information types in prompt text",
        "availability": "preview",
        "condition": "Content contains > Sensitive information types",
        "action": "Prevent Copilot from processing content > Processing prompts"
      },
      {
        "id": "externalWebSearchGroundingRestriction",
        "displayName": "Restrict external web search when prompt text contains sensitive information types",
        "availability": "preview",
        "condition": "Content contains > Sensitive information types",
        "action": "Prevent Copilot from processing content > Performing Web Searches"
      },
      {
        "id": "sensitivityLabelsOnSupportedFilesAndEmails",
        "displayName": "Sensitivity labels on supported files and emails used in response summarization",
        "availability": "generallyAvailable",
        "condition": "Content contains > Sensitivity labels",
        "action": "Prevent Copilot from processing content"
      }
    ],
    "complementaryWorkloadDlpPolicyLocations": [
      "Teams",
      "SharePoint",
      "OneDrive",
      "Exchange"
    ],
    "baselineStoragePath": ".\\artifacts\\dlp-policy-baseline.json",
    "driftThreshold": 10,
    "exceptionApprovalRequired": true,
    "policyModes": {
      "baseline": {
        "default": "Audit",
        "highSensitivity": "Audit"
      },
      "recommended": {
        "default": "Audit",
        "highSensitivity": "Block"
      },
      "regulated": {
        "default": "Audit",
        "highSensitivity": "Block",
        "npi": "Block",
        "pii": "Block"
      }
    },
    "policyScope": {
      "includedGroups": [
        "All Copilot Licensed Users"
      ],
      "excludedGroups": [
        "Break Glass Accounts"
      ]
    },
    "sensitivityConditions": [
      "Confidential",
      "Highly Confidential",
      "NPI",
      "PII"
    ]
  }
}
