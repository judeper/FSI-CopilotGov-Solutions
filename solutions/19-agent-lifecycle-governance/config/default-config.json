        "microsoft-365-copilot",
        "microsoft-viva-agent",
        "microsoft-teams-copilot"
      ]
    },
    "itDeveloped": {
      "description": "Agents developed by the organization IT or engineering teams using Copilot Studio or custom development frameworks.",
      "examples": [
        "contoso-helpdesk-agent",
        "contoso-compliance-assistant",
        "contoso-it-service-agent"
      ]
    },
