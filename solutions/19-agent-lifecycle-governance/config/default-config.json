      "description": "Agents created by business users in Copilot Studio without formal IT oversight.",
      "examples": [
        "dept-productivity-agent",
        "team-workflow-agent",
        "individual-assistant"
      ]
    },
    "blocked": {
      "description": "Agents prohibited in regulated Copilot contexts due to data handling, supervisory, or compliance concerns.",
      "examples": [
        "unapproved-third-party-agent",
        "unrestricted-external-agent"
      ]
    }
  },
  "sharingPolicyControls": {
    "orgWideSharingRestriction": {
      "description": "Controls whether Copilot Studio agents can be shared with the entire organization without admin approval.",
      "enforcementLevel": "admin-managed"
    },
    "externalSharingPolicy": {
      "description": "Controls whether agents can be shared with external users or guest accounts.",
      "enforcementLevel": "admin-managed"
    },
    "catalogVisibility": {
      "description": "Controls which agents appear in the M365 Admin Center agent catalog and which require explicit deployment approval.",
      "enforcementLevel": "admin-managed"
    }
  },
