{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://judeper.github.io/FSI-CopilotGov-Solutions/schemas/lab-validation-result.schema.json",
  "title": "FSI Lab Validation Result",
  "description": "Result envelope emitted by the lab executor for a single lab contract run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "resultId",
    "contractId",
    "solutionId",
    "generatedAt",
    "preflight",
    "summary",
    "stepResults",
    "blockers",
    "cleanup",
    "sourceVerification"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0(?:\\.\\d+)?$"
    },
    "resultId": {
      "type": "string",
      "pattern": "^lab-result:[a-z0-9][a-z0-9-]*:[a-z0-9][a-z0-9.-]*$"
    },
    "contractId": {
      "type": "string",
      "pattern": "^lab-contract:[a-z0-9][a-z0-9-]*:[a-z0-9][a-z0-9.-]*$"
    },
    "solutionId": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z0-9-]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "checkedOn",
        "notes"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "GO",
            "HOLD",
            "NO-GO"
          ]
        },
        "checkedOn": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 4000
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "disposition",
        "accepted",
        "controlImplementation",
        "notes"
      ],
      "properties": {
        "disposition": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "BLOCKED",
            "NOT-APPLICABLE",
            "FAIL"
          ]
        },
        "accepted": {
          "type": "boolean"
        },
        "controlImplementation": {
          "type": "string",
          "enum": [
            "implemented",
            "partial",
            "not-implemented",
            "not-evaluated"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 4000
        }
      }
    },
    "stepResults": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stepResult"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "cleanup": {
      "$ref": "#/$defs/cleanup"
    },
    "sourceVerification": {
      "$ref": "#/$defs/sourceVerification"
    },
    "evidencePackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  },
  "$defs": {
    "stepResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phaseId",
        "stepId",
        "outcome",
        "notes",
        "readBackVerified",
        "mutationExecuted",
        "mutationRef",
        "evidenceRefs"
      ],
      "properties": {
        "phaseId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "stepId": {
          "type": "string",
          "pattern": "^step-[a-z0-9-]+$"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "BLOCKED",
            "NOT-RUN",
            "NOT-APPLICABLE"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 4000
        },
        "readBackVerified": {
          "type": "boolean"
        },
        "mutationExecuted": {
          "type": "boolean"
        },
        "mutationRef": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^mutation-[a-z0-9-]+$"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mutationExecuted": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "mutationRef": {
                "type": "string",
                "pattern": "^mutation-[a-z0-9-]+$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mutationExecuted": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "mutationRef": {
                "const": null
              }
            }
          }
        }
      ]
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reason",
        "evidenceRefs",
        "sourceClaimIds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^blocker-[a-z0-9-]+$"
        },
        "reason": {
          "type": "string",
          "minLength": 5,
          "maxLength": 4000
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceClaimIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^claim-[a-z0-9-]+$"
          }
        }
      }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "completedBy",
        "notes",
        "orphanedMutations"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "not-required",
            "not-started",
            "completed",
            "partial",
            "failed",
            "orphaned"
          ]
        },
        "completedBy": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200
        },
        "notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 4000
        },
        "orphanedMutations": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^mutation-[a-z0-9-]+$"
          }
        }
      }
    },
    "sourceVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claims"
      ],
      "properties": {
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claimId",
              "status",
              "checkedOn",
              "evidenceRefs",
              "sourceUrl"
            ],
            "properties": {
              "claimId": {
                "type": "string",
                "pattern": "^claim-[a-z0-9-]+$"
              },
              "status": {
                "type": "string",
                "enum": [
                  "verified",
                  "negative-verified",
                  "stale",
                  "not-verified"
                ]
              },
              "checkedOn": {
                "type": "string",
                "format": "date-time"
              },
              "evidenceRefs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "sourceUrl": {
                "type": "string",
                "format": "uri",
                "pattern": "^https://"
              }
            }
          }
        }
      }
    }
  }
}
