{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/judeper/FSI-CopilotGov-Solutions/data/data-classification.schema.json",
  "title": "FSI Copilot Solution Data Classification Matrix",
  "description": "Per-solution data classification, residency, and retention metadata. Conservative documentation-first defaults; production deployments must reclassify per the firm's data taxonomy.",
  "type": "array",
  "minItems": 23,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "slug",
      "data_classes_processed",
      "residency_options",
      "retention_default_days",
      "retention_max_days",
      "notes"
    ],
    "properties": {
      "slug": {
        "type": "string",
        "pattern": "^[0-9]{2}-[a-z0-9-]+$"
      },
      "data_classes_processed": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted",
            "regulated-pii",
            "regulated-financial"
          ]
        }
      },
      "residency_options": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "enum": [
            "commercial",
            "gcc",
            "gcc-high",
            "dod",
            "eu-data-boundary"
          ]
        }
      },
      "retention_default_days": {
        "type": "integer",
        "minimum": 1,
        "maximum": 36500
      },
      "retention_max_days": {
        "type": "integer",
        "minimum": 1,
        "maximum": 36500
      },
      "notes": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
