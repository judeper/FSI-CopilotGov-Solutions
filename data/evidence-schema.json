{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://judeper.github.io/FSI-CopilotGov-Solutions/schemas/evidence-schema.json",
  "title": "FSI Copilot Governance Evidence Package",
  "type": "object",
  "required": [
    "metadata",
    "summary",
    "controls",
    "artifacts"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "solution",
        "solutionCode",
        "exportVersion",
        "exportedAt",
        "tier"
      ],
      "properties": {
        "solution": {
          "type": "string"
        },
        "solutionCode": {
          "type": "string"
        },
        "exportVersion": {
          "type": "string"
        },
        "exportedAt": {
          "type": "string",
          "format": "date-time"
        },
        "tier": {
          "type": "string",
          "enum": [
            "baseline",
            "recommended",
            "regulated"
          ]
        },
        "periodStart": {
          "type": "string",
          "format": "date"
        },
        "periodEnd": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "overallStatus",
        "recordCount"
      ],
      "properties": {
        "overallStatus": {
          "type": "string",
          "enum": [
            "implemented",
            "partial",
            "monitor-only",
            "playbook-only",
            "error"
          ]
        },
        "recordCount": {
          "type": "integer",
          "minimum": 0
        },
        "findingCount": {
          "type": "integer",
          "minimum": 0
        },
        "exceptionCount": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "controlId",
          "status"
        ],
        "properties": {
          "controlId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "implemented",
              "partial",
              "monitor-only",
              "playbook-only"
            ]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
