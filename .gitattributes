# Append-only Squad state — keep all lines from both sides on merge.
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union

# Hash fixtures must have identical bytes on Windows and Linux.
scripts/tests/fixtures/lab-package/**/*.json text eol=lf
scripts/tests/fixtures/lab-package/**/*.sha256 text eol=lf
