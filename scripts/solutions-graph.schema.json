{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fsi-copilotgov-solutions/solutions-graph.schema.json",
  "title": "FSI-CopilotGov-Solutions Solutions Graph",
  "description": "Canonical inventory of solutions and framework control coverage. Generated by scripts/build_solutions_graph.py.",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "counts", "solutions", "framework_controls_referenced"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "counts": {
      "type": "object",
      "required": [
        "solutions",
        "tier1",
        "tier2",
        "tier3",
        "framework_controls_referenced",
        "doc_files_total"
      ],
      "additionalProperties": false,
      "properties": {
        "solutions": {"type": "integer", "minimum": 0},
        "tier1": {"type": "integer", "minimum": 0},
        "tier2": {"type": "integer", "minimum": 0},
        "tier3": {"type": "integer", "minimum": 0},
        "framework_controls_referenced": {"type": "integer", "minimum": 0},
        "doc_files_total": {"type": "integer", "minimum": 0}
      }
    },
    "solutions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "tier", "version", "domain", "controlCoverage", "docFileCount"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "tier": {"type": ["integer", "null"], "minimum": 1, "maximum": 3},
          "version": {"type": "string"},
          "domain": {"type": "string"},
          "controlCoverage": {
            "type": "array",
            "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+[a-z]?$"}
          },
          "docFileCount": {"type": "integer", "minimum": 0}
        }
      }
    },
    "framework_controls_referenced": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+[a-z]?$"}
    }
  }
}
